generator client {
  provider = "prisma-client"
  output   = "./generated/"
}
datasource db {
  provider = "sqlite"
}

model Users {
  id String @id @default(uuid())
  name String
  email String @unique
  createdAt DateTime @default(now())

  Accounts Accounts[]
  Sessions Sessions[]
  healthProfiles HealthProfiles[]
}

model Accounts {
  id Int @id @default(autoincrement())
  userId String
  provider String
  providerId String
  accessToken String
  refreshToken String?
  tokenExpiry DateTime?

  user Users @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerId])
}

model Sessions {
  id          String   @id
  userId   String
  userAgent   String?
  ipAddress   String?
  expiresIn    DateTime
  createdAt    DateTime @default(now())

  user     Users  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model HealthProfiles {
  id Int @id @default(autoincrement())
  userId String
  firstName String
  lastName String
  weight Int
  weightSampleTime DateTime?
  height Int
  heightSampleTime DateTime?
  age String?
  objective String

  user     Users  @relation(fields: [userId], references: [id], onDelete: Cascade)
}