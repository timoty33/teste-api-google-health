generator client {
  provider = "prisma-client"
  output   = "./generated/"
}
datasource db {
  provider = "sqlite"
}

model Usuarios {
  id String @id @default(uuid())
  nome String
  email String @unique
  criadoEm DateTime @default(now())

  contas Contas[]
  sessoes Sessoes[]
}

model Contas {
  id Int @id @default(autoincrement())
  usuarioId String
  provedor String
  provedorId String
  acessToken String
  refreshToken String?
  tokenExpiry DateTime?

  usuario Usuarios @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  @@unique([provedor, provedorId])
}

model Sessoes {
  id          String   @id // O token gerado para o Cookie (pode ser um token aleatório longo)
  usuarioId   String
  userAgent   String?
  ipAddress   String?
  expiraEm    DateTime
  criadoEm    DateTime @default(now())

  usuario     Usuarios  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}